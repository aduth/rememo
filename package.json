{
	"name": "rememo",
	"type": "module",
	"version": "4.0.2",
	"description": "Memoized selectors for Redux and other immutable object derivation",
	"main": "./dist/rememo.cjs",
	"module": "./dist/rememo.mjs",
	"types": "./dist/rememo.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/rememo.d.mts",
				"default": "./dist/rememo.mjs"
			},
			"require": {
				"types": "./dist/rememo.d.cts",
				"default": "./dist/rememo.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"test:lint": "eslint . --ext .js,.ts --ignore-pattern dist",
		"test:typecheck": "tsc",
		"test:unit": "vitest run",
		"test": "npm-run-all --parallel test:*",
		"build": "tsdown",
		"dev": "tsdown --watch",
		"prepublishOnly": "npm run build"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/aduth/rememo.git"
	},
	"bugs": {
		"url": "https://github.com/aduth/rememo/issues"
	},
	"author": {
		"name": "Andrew Duthie",
		"email": "andrew@andrewduthie.com",
		"url": "http://andrewduthie.com"
	},
	"keywords": [
		"redux",
		"selector",
		"selectors",
		"memoize",
		"memoization",
		"cache"
	],
	"license": "MIT",
	"devDependencies": {
		"@aduth/eslint-config": "^4.4.1",
		"@typescript-eslint/eslint-plugin": "^8.61.0",
		"@typescript-eslint/parser": "^8.61.0",
		"eslint": "^8.24.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-jsdoc": "^39.3.6",
		"eslint-plugin-prettier": "^4.2.1",
		"npm-run-all": "^4.1.5",
		"prettier": "^2.7.1",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.7"
	}
}
